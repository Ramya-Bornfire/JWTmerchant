<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".AdminScreens.DeviceManagement">
    <include layout="@layout/background_image" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_marginLeft="20dp"
                        android:id="@+id/backBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:src="@drawable/back_btn_ic"></ImageView>
                    <TextView
                        android:layout_marginLeft="10dp"
                        android:id="@+id/txt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/device_list"
                        android:textSize = "20dp"
                        android:textColor="@color/white"
                        android:textStyle="bold">
                    </TextView>
                </LinearLayout>
                <FrameLayout
                    android:layout_marginTop="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <EditText
                        android:layout_marginRight="20dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:id="@+id/editFilter"
                        android:layout_width="200dp"
                        android:layout_height="30dp"
                        android:hint="Search"
                        android:textColor="@color/white"
                        android:maxLines="1"
                        android:textColorHint="@color/white"                            android:background="@drawable/textfiled_background"
                        android:paddingStart="8dp"
                        android:paddingEnd="40dp" /> <!-- Adjust padding as needed -->
                </FrameLayout>
                <Button
                    android:id="@+id/addBtn"
                    android:text="Add"
                    android:layout_marginTop="10dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="30dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    ></Button>
                <ImageView
                    android:id="@+id/dm_help_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="20dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/ic_help"/>
            </LinearLayout>
    <TableLayout
        android:id="@+id/tableLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
    </TableLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/emptyTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:drawableLeft="@android:drawable/stat_sys_warning"
        android:text="No records available"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:visibility="gone" />
</RelativeLayout>
