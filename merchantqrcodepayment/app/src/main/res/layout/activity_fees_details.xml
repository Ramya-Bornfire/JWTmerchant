<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DetailScreen.FeesDetails">
    <include layout="@layout/background_image" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_marginLeft="10dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Message Ref"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Audit Ref"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bank"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remitter Account"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Currency"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amount"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transaction Fees"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Applied Flag"
                        android:textColor="@color/white"
                        android:textSize="15dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="2"
                    android:layout_marginLeft="40dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/date"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/msgref"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/auditref"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/bank1"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/remacc"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/currency"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/amtText"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/transFee"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                    <EditText
                        android:paddingLeft="10dp"
                        android:layout_marginTop="5dp"
                        android:id="@+id/appFlag"
                        android:textColor="@color/white"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="@drawable/textfiled_background"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
