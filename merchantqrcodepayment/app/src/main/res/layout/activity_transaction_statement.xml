<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TransactionStatement">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/back_img"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/back_btn_ic"
                android:layout_gravity="start"/>
            <TextView
                android:layout_marginLeft="20dp"
                android:textSize="20dp"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transaction Statement"></TextView>
        </LinearLayout>
        <ImageView
            android:layout_marginRight="20dp"
            android:id="@+id/shareBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/share_btn"
            android:layout_gravity="right"/>
        <ImageView
            android:layout_marginRight="20dp"
            android:id="@+id/downloadbtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/file_download"
            android:layout_gravity="right"/>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_marginTop="70dp"
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/accType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="25dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:text="Current and Saving Account Statement"></TextView>

        <LinearLayout
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="40dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/address1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Bornfire Innovations Private Limited"></TextView>
            <TextView
                android:id="@+id/address2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Viji Nivas, second floor"></TextView>
            <TextView
                android:id="@+id/address3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="10, Soundaraiyar street"></TextView>
            <TextView
                android:id="@+id/address4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Ammapet, Salem"></TextView>
        </LinearLayout>
            <TextView
                android:id="@+id/accStatementDate"
                android:layout_marginTop="30dp"
                android:layout_marginRight="40dp"
                android:layout_gravity="end"

                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Statement as of 14-07-2023 16:41:34 +0530"/>
            <LinearLayout
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@drawable/box_background"
                android:orientation="vertical">

            <LinearLayout
                android:background="@drawable/box_background"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Merchant Id"
                    />

                <EditText
                    android:id="@+id/merchantId"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Merchant Name"
                    />

                <EditText
                    android:id="@+id/merchantName"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Representative Id"
                    />

                <EditText
                    android:id="@+id/repId"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Representative Name"
                    />

                <EditText
                    android:id="@+id/repName"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"

                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Unit Name"
                    />

                <EditText
                    android:id="@+id/unitName"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Unit Id"
                    />

                <EditText
                    android:id="@+id/unitId"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Device Id"
                    />

                <EditText
                    android:id="@+id/deviceId"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Account Number"
                    />

                <EditText
                    android:id="@+id/accNumber"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"

                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Account Currency"
                    />

                <EditText
                    android:id="@+id/accCurrency"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">
                <EditText
                    android:editable="false"
                    android:focusable="false"
                    android:paddingLeft="10dp"
                    android:hint="Search by"
                    android:id="@+id/searchBy"
                    android:textColor="@color/black"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:layout_width="0dp"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    ></EditText>

                <EditText
                    android:id="@+id/searchQuery"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:focusable="false"
                    android:editable="false"
                    android:id="@+id/fromdate"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
                <EditText
                    android:focusable="false"
                    android:editable="false"
                    android:id="@+id/toDate"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            </LinearLayout>
            <Button
                android:id="@+id/stmtbutton"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Statement"/>

            <TableLayout
                android:layout_marginTop="20dp"
                android:layout_marginLeft="40dp"
                android:layout_marginRight="40dp"
                android:id="@+id/StatetableLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
            </TableLayout>

            <Button
                android:visibility="gone"
                android:id="@+id/generateBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generate PDF" />
        </LinearLayout>

    </ScrollView>
</RelativeLayout>