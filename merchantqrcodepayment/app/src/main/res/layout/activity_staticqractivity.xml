<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".staticqractivity">
        <include layout="@layout/background_image" />
        <LinearLayout
            android:layout_width="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_height="match_parent">
                <TextView
                    android:layout_marginBottom="20dp"
                    android:layout_width="match_parent"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:id="@+id/header"
                    android:textColor="@color/white"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:textSize="20dp"
                    android:textStyle="bold"
                    android:text="SCAN AND PAY"/>
                <ImageView
                    android:id="@+id/qrCodeImageView"
                    android:layout_width="400dp"
                    android:layout_height="400dp"
                    android:layout_centerInParent="true"/>
                <TextView
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/body"
                    android:textColor="@color/orange"
                    android:textSize="22dp"
                    android:textStyle="bold"
                    android:text="MERCHANT QR CODE PAYMENT"/>
                <TextView
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/scanandpay"
                    android:textColor="@color/white"
                    android:textSize="14dp"
                    android:text="SCAN AND PAY FROM MOBILE APP"/>
                <!--<LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/gpayImageView"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_gpay"
                            android:layout_centerInParent="true"/>
                        <ImageView
                            android:id="@+id/paytmImageView"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_gpay"
                            android:layout_centerInParent="true"/>
                        <ImageView
                            android:id="@+id/phonepayImageView"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_gpay"
                            android:layout_centerInParent="true"/>
                </LinearLayout>-->
                <ImageView
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:id="@+id/phonepayImageView"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:visibility="gone"
                    android:src="@drawable/banklogo" />
                <TextView
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/choice"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="14dp"
                    android:visibility="gone"
                    android:textStyle="italic"
                    android:text="of your choice"/>
                <LinearLayout
                    android:layout_marginLeft="40dp"
                    android:layout_marginRight="40dp"
                    android:layout_marginTop="40dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                        <Button
                            android:id="@+id/sharebtn"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="Share"
                            android:layout_gravity="center"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="4dp"/>
                        <Button
                            android:id="@+id/downloadbtn"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="Download"
                            android:layout_gravity="center"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="8dp"/>
                </LinearLayout>
        </LinearLayout>
</RelativeLayout>