<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".DetailScreen.ServiceRequestDetails">
    <include layout="@layout/background_image" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_marginTop="80dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <LinearLayout
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_marginLeft="10dp"
                        android:layout_width="wrap_content"
                        android:layout_gravity="center"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Record SRL No*"
                            android:textColor="@color/white"
                            android:textSize="15dp"
                            ></TextView>

                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Event Number *"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                        <TextView
                            android:layout_gravity="start"
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notification Limit "
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                        <TextView
                            android:layout_gravity="start"
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notification User 1 "
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                        <TextView
                            android:layout_gravity="start"
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notification User 2"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>

                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notification User 3"
                            android:textColor="@color/white"
                            android:textSize="15dp"
                            ></TextView>
                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Id 1"
                            android:textColor="@color/white"
                            android:textSize="15dp"
                            ></TextView>
                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Id 2"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>

                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Id 3"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_marginLeft="40dp"
                        android:layout_marginRight="10dp"
                        android:layout_gravity="center"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <EditText
                            android:paddingLeft="10dp"
                            android:id="@+id/editsrlNo"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:maxLines="1"
                            android:inputType="textCapCharacters"
                            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>

                        <EditText
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:id="@+id/editEveNo"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:inputType="textCapCharacters"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <EditText
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:id="@+id/editNotLimit"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                            android:inputType="text"
                            android:hint="Select"
                            android:textColorHint="@color/lightgrey"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <EditText
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:id="@+id/editNotiUser1"
                            android:hint="Select"
                            android:textColorHint="@color/lightgrey"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:inputType="text"
                            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <EditText
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:hint="Select"
                            android:textColorHint="@color/lightgrey"
                            android:id="@+id/editNotiUser2"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:inputType="text"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>

                        <EditText
                            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                            android:id="@+id/editNotiUser3"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:maxLines="1"
                            android:inputType="textCapCharacters"
                            android:textColor="@color/white"
                            android:background="@drawable/textfiled_background"
                            />

                        <EditText
                            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                            android:id="@+id/editEmail1"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:textColor="@color/white"
                            android:maxLines="1"
                            android:background="@drawable/textfiled_background"
                            />


                        <EditText
                            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                            android:id="@+id/editEmail2"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:textColor="@color/white"
                            android:background="@drawable/textfiled_background"
                            />
                        <EditText
                            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                            android:id="@+id/editEmail3"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:textColor="@color/white"
                            android:background="@drawable/textfiled_background"
                            />


                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_marginLeft="10dp"
                        android:layout_width="wrap_content"
                        android:layout_gravity="center"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Record Date *"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                        <TextView
                            android:layout_gravity="start"
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tran Category *"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Event Description *"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                        <TextView
                            android:layout_gravity="start"
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mobile 1"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                        <TextView
                            android:layout_gravity="start"
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mobile 2"
                            android:textColor="@color/white"
                            android:textSize="15dp"></TextView>
                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mobile 3"
                            android:textColor="@color/white"
                            android:textSize="15dp"
                            ></TextView>
                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SMS"
                            android:textColor="@color/white"
                            android:textSize="15dp"
                            ></TextView>
                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email"
                            android:textColor="@color/white"
                            android:textSize="15dp"
                            ></TextView>
                        <TextView
                            android:layout_marginTop="25dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alert"
                            android:textColor="@color/white"
                            android:textSize="15dp"
                            ></TextView>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_marginLeft="40dp"
                        android:layout_marginRight="10dp"
                        android:layout_gravity="center"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <EditText
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:id="@+id/editRecDate"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:maxLines="1"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <EditText
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:id="@+id/editTranCate"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:inputType="text"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <EditText
                            android:paddingLeft="10dp"
                            android:layout_marginTop="5dp"
                            android:id="@+id/editEveDesc"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:inputType="textCapCharacters"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <EditText
                            android:paddingLeft="10dp"
                            android:layout_marginTop="5dp"
                            android:id="@+id/editMob1"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:inputType="textCapCharacters"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <EditText
                            android:paddingLeft="10dp"
                            android:layout_marginTop="5dp"
                            android:id="@+id/editMob2"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <EditText
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10dp"
                            android:id="@+id/editMob3"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:inputType="text"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></EditText>
                        <AutoCompleteTextView
                            android:paddingLeft="10dp"
                            android:layout_marginTop="5dp"
                            android:id="@+id/editSMS"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:inputType="textCapCharacters"
                            android:background="@drawable/textfiled_background"
                            ></AutoCompleteTextView>
                        <AutoCompleteTextView
                            android:paddingLeft="10dp"
                            android:layout_marginTop="5dp"
                            android:id="@+id/editEmail"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:inputType="textCapCharacters"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></AutoCompleteTextView>
                        <AutoCompleteTextView
                            android:paddingLeft="10dp"
                            android:layout_marginTop="5dp"
                            android:id="@+id/editAlert"
                            android:textColor="@color/white"
                            android:layout_width="300dp"
                            android:layout_height="40dp"
                            android:background="@drawable/textfiled_background"
                            ></AutoCompleteTextView>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_marginTop="40dp"
                android:layout_marginBottom="40dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal">
                <Button
                    android:layout_gravity="center"
                    android:id="@+id/notifyBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:layout_marginTop="16dp"
                    android:text="Add Notification"/>
                <Button
                    android:visibility="gone"
                    android:layout_gravity="center"
                    android:id="@+id/verifyBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:layout_marginTop="16dp"
                    android:text="Verify"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>