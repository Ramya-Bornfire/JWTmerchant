<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DetailScreen.TransactionDetails">

    <include layout="@layout/background_image" />

    <ScrollView
        android:id="@+id/tran_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">
            <!-- Bill Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/tran_date_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tran Date"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/transEditBillDate"
                    android:paddingLeft="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>
            <!-- Bill Number -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/bill_num_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bill Number"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:textSize="15sp"
                    android:id="@+id/tranSEditBillNumber"
                    android:paddingLeft="10dp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>

            <!-- Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/cus_name_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Customer Name"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:textSize="15sp"
                    android:id="@+id/transEditName"
                    android:paddingLeft="10dp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>

            <!-- Device Id -->
            <LinearLayout
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Device Id"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:textSize="15sp"
                    android:id="@+id/transEditDeviceId"
                    android:paddingLeft="10dp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>

            <!-- User Id -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/usr_id_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="User ID"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/transEditUserId"
                    android:textSize="15sp"
                    android:paddingLeft="10dp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>

            <!-- Currency -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/curncy_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Currency"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/transEditCurrency"
                    android:paddingLeft="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>
            <!-- Bill Amount -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/tran_amt_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tran Amount"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:textSize="15sp"
                    android:id="@+id/transEditBillAmount"
                    android:paddingLeft="10dp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>

            <!-- Transaction Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/bill_date_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bill Date"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/transEditTransactionDate"
                    android:paddingLeft="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>

            <!-- Amount -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/bill_amt_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bill Amount"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/transEditAmount"
                    android:paddingLeft="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>

            <!-- Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/sts_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Status"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/transEditStatus"
                    android:paddingLeft="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>
            <!-- Approved User -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/apr_usr_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Approved User"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/aprby"
                    android:paddingLeft="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>
            <!-- Approved Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/apr_date_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Approved Date"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/aprdate"
                    android:paddingLeft="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>
            <!-- Reversal Remark -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <TextView
                    android:id="@+id/rmk_txt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Remarks"
                    android:textColor="@color/white"
                    android:textSize="15sp" />
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="2"
                    android:id="@+id/revremark"
                    android:paddingLeft="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/lightgrey"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>
            <LinearLayout
                android:layout_marginLeft="40dp"
                android:layout_marginRight="40dp"
                android:layout_marginTop="40dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/pdf_btn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="Print"
                    android:layout_gravity="center"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"/>
                <Button
                    android:id="@+id/save_btn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="Save"
                    android:layout_gravity="center"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
