<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
   style="@style/llmv"
    tools:context=".DetailScreen.UserDetailsActivity">
    <include layout="@layout/background_image" />
    <ScrollView
        style="@style/WH2">
        <LinearLayout
           style="@style/llmv">
            <LinearLayout
                style="@style/llwh"
                android:layout_marginTop="20dp"
                android:layout_gravity="center">
                <LinearLayout
                    style="@style/llwv"
                    android:layout_marginLeft="10dp"
                    android:layout_gravity="center">
                    <TextView
                        android:layout_marginTop="-5dp"
                       style="@style/DetailsText"
                        android:text="Date"/>
                    <TextView
                        android:text="Message Ref"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="Bill Number"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="User Id"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="Customer Name"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="Bank"
                        style="@style/DetailsText"/>
                    <TextView
                        android:visibility="gone"
                        android:text="Remitter Account"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="Beneficiary"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="Currency"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="Amount"
                        style="@style/DetailsText"/>
                    <TextView
                        android:visibility="gone"
                        android:text="Reversal Remark"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="Remarks"
                        style="@style/DetailsText"/>
                    <TextView
                        android:text="Status"
                        style="@style/DetailsText"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_marginStart="40dp"
                    android:layout_marginEnd="10dp"
                    android:layout_gravity="center"
                    style="@style/llwv">
                    <EditText
                        style="@style/UDedtext"
                        android:id="@+id/date"/>
                    <EditText
                        android:id="@+id/msgref"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/billnum"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/userid"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/custname"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/bank1"
                        style="@style/UDedtext"/>
                    <EditText
                        android:visibility="gone"
                        android:id="@+id/remacc"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/benacc"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/currency"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/amtText"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/particular"
                        android:visibility="gone"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/remarks"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/status"
                        style="@style/UDedtext"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>