<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".DetailScreen.ChargeBackDetailsActivity">
    <include layout="@layout/background_image" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_marginLeft="40dp"
        android:layout_marginRight="40dp"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_marginLeft="10dp"
                android:layout_width="wrap_content"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    style="@style/DetailsText"
                    android:text="Tran Date"/>
                <TextView
                    android:text="Message ID"
                    style="@style/DetailsText"/>
                <TextView
                    android:text="Audit Ref"
                    android:visibility="gone"
                    style="@style/DetailsText"/>
                <TextView
                    android:text="Bill Number"
                    style="@style/DetailsText"/>
                <TextView
                    android:text="Bill Date"
                    style="@style/DetailsText"/>
                <TextView
                    android:text="Currency"
                    style="@style/DetailsText"/>
                <TextView
                    android:text="Bill Amount"
                    style="@style/DetailsText"/>
                <TextView
                    android:text="Approved User"
                    style="@style/DetailsText"/>
                <TextView
                    android:text="Approved Date"
                    style="@style/DetailsText"/>
                <TextView
                    style="@style/DetailsText"
                    android:text="Remarks"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_marginLeft="40dp"
                android:layout_marginRight="10dp"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <EditText
                    android:layout_marginTop="20dp"
                    android:id="@+id/editTranDate"
                    style="@style/UDedtext"/>
                <EditText
                    android:id="@+id/editMsgId"
                    style="@style/UDedtext"/>
                <EditText
                    android:visibility="gone"
                    android:id="@+id/editAuditRef"
                    style="@style/UDedtext"/>
                <EditText
                    android:id="@+id/editBillNo"
                    style="@style/UDedtext"/>
                <EditText
                    android:id="@+id/editBillDate"
                    android:textColor="@color/lightgrey"
                    style="@style/UDedtext"/>
                <EditText
                    android:id="@+id/Crncy"
                    style="@style/UDedtext"/>
                <EditText
                    android:id="@+id/editBillAmount"
                    style="@style/UDedtext"/>
                <EditText
                    android:editable="false"
                    android:id="@+id/aprby"
                    style="@style/UDedtext"/>
                <EditText
                    android:editable="false"
                    android:id="@+id/aprdate"
                    style="@style/UDedtext"/>
                <EditText
                    android:editable="false"
                    android:id="@+id/editRemarks"
                    style="@style/UDedtext"/>
                <Spinner
                    android:visibility="gone"
                    android:id="@+id/spinnerRemarks"
                    android:layout_width="300dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="5dp"
                    android:paddingLeft="10dp"
                    android:textColor="@color/white"
                    android:background="@drawable/textfiled_background" />
            </LinearLayout>
        </LinearLayout>
            <Button
                android:layout_gravity="center"
                android:id="@+id/submitbtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:layout_marginTop="16dp"
                android:text="Revert"/>
    </LinearLayout>
    </ScrollView>
</RelativeLayout>

