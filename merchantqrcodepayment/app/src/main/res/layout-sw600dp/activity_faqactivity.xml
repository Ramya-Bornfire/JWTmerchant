<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".faqactivity">
    <include layout="@layout/background_image" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginBottom="10dp"
        android:layout_margin="10dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que1"
            android:text="1. How do Merchant QR Code Payments Work?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans1"
            android:text="Merchant QR code payments allow customers to scan a unique QR code generated by the merchant to initiate a payment transaction. The customer's payment information is securely processed, and the merchant receives the payment"
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que2"
            android:text="2. How Can I Generate a Merchant QR Code?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans2"
            android:text="To generate a merchant QR code, navigate to the Generate QR Code section in the app. Enter the transaction details, such as the amount and a brief description. The app will generate a unique QR code that customers can scan to make payments."
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que3"
            android:text="3. What Information is Included in the QR Code?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans3"
            android:text="The QR code includes essential transaction details, such as the merchant's identification, transaction amount, and other relevant information. It is designed to be secure and efficient for payment processing."
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que4"
            android:text="4. Can I Customize the QR Code?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans4"
            android:text="Yes, within the app, you can customize certain aspects of the QR code generation, such as adding a logo or changing the color scheme. However, ensure that the QR code remains scannable and compliant with payment standards."
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que5"
            android:text="5. Is Merchant QR Code Payment Secure?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans5"
            android:text="Yes, our app employs robust security measures to protect both merchants and customers during transactions. We use encryption and follow industry standards to ensure the security of payment information."
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que6"
            android:text="6. What Payment Methods are Supported?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans6"
            android:text="The app supports various payment methods, including credit/debit cards, digital wallets, and UPI. The specific payment methods available may vary depending on the customer's choice."
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que7"
            android:text="7. How Do I View Transaction History?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans7"
            android:text="You can view your transaction history within the app. Navigate to the Transaction History section to see a detailed record of all payments received, including timestamps and transaction details."
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que8"
            android:text="8. What if a Customer Faces Issues Scanning the QR Code?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans8"
            android:text="If a customer faces issues scanning the QR code, ensure that the QR code is displayed clearly. If the problem persists, provide alternative payment methods or verify that the customer's scanning app is compatible."
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que9"
            android:text="9. How Can I Contact Support?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans9"
            android:text="If you encounter any issues or have specific questions, you can contact our support team through the Contact Support option in the app. We are here to assist you."
            android:textSize="18dp"
            android:textColor="@color/white"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/que10"
            android:text="10. What Security Measures Should Merchants Follow?"
            android:textSize="20dp"
            android:textColor="@color/orange"></TextView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/ans10"
            android:text="Merchants are advised to keep their app and device secure. Do not share sensitive information, and regularly update your app to benefit from the latest security enhancements."
            android:textSize="18dp"
            android:layout_marginBottom="10dp"
            android:textColor="@color/white"></TextView>

    </LinearLayout>
    </ScrollView>
</RelativeLayout>