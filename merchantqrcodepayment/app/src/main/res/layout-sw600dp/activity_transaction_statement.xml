<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TransactionStatement">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/back_img"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/back_btn_ic"
                android:layout_gravity="start"/>
            <TextView
                android:layout_marginLeft="20dp"
                android:textSize="20dp"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transaction Statement"></TextView>
        </LinearLayout>
        <ImageView
            android:layout_gravity="right"
            android:layout_marginRight="20dp"
            android:id="@+id/ts_help_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_help"/>
        <ImageView
            android:layout_marginRight="20dp"
            android:id="@+id/downloadbtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/file_download"
            android:layout_gravity="right"/>
        <ImageView
            android:layout_marginRight="20dp"
            android:id="@+id/filterButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_filter"
            android:layout_gravity="right"/>
        <ImageView
            android:layout_marginRight="20dp"
            android:id="@+id/refreshBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_refresh"
            android:layout_gravity="right"/>

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_marginTop="70dp"
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="300dp"
                android:src="@drawable/bob_logo1"
                android:layout_gravity="center"></ImageView>

            <TextView
                android:id="@+id/accType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="25dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:text="Account Statement"></TextView>

        <LinearLayout
            android:layout_marginRight="100dp"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
           android:layout_gravity="left"
            android:layout_marginLeft="40dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/address1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Bank of Baroda"></TextView>
            <TextView
                android:id="@+id/address2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="492, BLUE JACKET STREET"></TextView>

            <TextView
                android:id="@+id/address3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="FRANCISTOWN, BOTSWANA"></TextView>
            <TextView
                android:visibility="gone"
                android:id="@+id/address4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:text="Botswana"></TextView>
        </LinearLayout>
            <TextView
                android:id="@+id/accStatementDate"
                android:layout_marginTop="30dp"
                android:textSize="20dp"
                android:layout_gravity="right"
                android:layout_marginRight="40dp"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <LinearLayout
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:padding="20dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginRight="41dp"
                android:layout_gravity="right">
                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="wrap_content"
                    android:paddingRight="10dp"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:editable="false"
                    android:focusable="false"
                    android:background="@drawable/box_background"
                    android:text="For Merchant" />
                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="wrap_content"
                    android:paddingRight="10dp"
                    android:maxLines="1"
                    android:editable="false"
                    android:focusable="false"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:id="@+id/topmerchantid"
                    android:background="@drawable/box_background" />
                <EditText
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="wrap_content"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:id="@+id/topmerchantname"
                    android:background="@drawable/box_background"
                    android:editable="false"
                    android:paddingRight="10dp"
                    android:focusable="false" />
            </LinearLayout>



            <LinearLayout
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="40dp"
                android:layout_marginRight="40dp"
                android:layout_gravity="center"
                android:background="@drawable/box_background"
                android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:editable="false"
                    android:focusable="false"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Representative Id"
                    />

                <EditText
                    android:editable="false"
                    android:focusable="false"
                    android:id="@+id/repId"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:editable="false"
                    android:focusable="false"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Representative Name"
                    />

                <EditText
                    android:editable="false"
                    android:focusable="false"
                    android:id="@+id/repName"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"

                    />

            </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center">

                    <EditText
                        android:editable="false"
                        android:focusable="false"
                        android:paddingLeft="10dp"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:layout_height="40dp"
                        android:background="@drawable/box_background"
                        android:text="Account Number"
                        />

                    <EditText
                        android:cursorVisible="false"
                        android:editable="false"
                        android:focusable="false"
                        android:id="@+id/accNumber"
                        android:paddingLeft="10dp"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:inputType="textCapCharacters"
                        android:layout_height="40dp"
                        android:background="@drawable/box_background"

                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center">

                    <EditText
                        android:editable="false"
                        android:focusable="false"
                        android:paddingLeft="10dp"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:layout_height="40dp"
                        android:background="@drawable/box_background"
                        android:text="Currency"
                        />

                    <EditText
                        android:editable="false"
                        android:focusable="false"
                        android:id="@+id/accCurrency"
                        android:paddingLeft="10dp"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:inputType="textCapCharacters"
                        android:layout_height="40dp"
                        android:background="@drawable/box_background"
                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center">

                    <EditText
                        android:editable="false"
                        android:focusable="false"
                        android:paddingLeft="10dp"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:layout_height="40dp"
                        android:background="@drawable/box_background"
                        android:text="Unit Id"
                        />

                    <EditText
                        android:id="@+id/unitId"
                        android:paddingLeft="10dp"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:maxLines="1"
                        android:inputType="textCapCharacters"
                        android:layout_height="40dp"
                        android:background="@drawable/box_background"
                        />
                </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:editable="false"
                    android:focusable="false"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Unit Name"
                    />

                <EditText
                    android:cursorVisible="false"
                    android:id="@+id/unitName"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:visibility="gone"
                android:id="@+id/deviceLay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:editable="false"
                    android:focusable="false"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    android:text="Device Id"
                    />

                <EditText
                    android:cursorVisible="false"
                    android:id="@+id/deviceId"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/searchLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">
                <EditText
                    android:editable="false"
                    android:focusable="false"
                    android:paddingLeft="10dp"
                    android:hint="Search by"
                    android:id="@+id/searchBy"
                    android:textColor="@color/black"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:layout_width="0dp"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    ></EditText>

                <EditText
                    android:id="@+id/searchQuery"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:cursorVisible="false"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/dateLay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <EditText
                    android:focusable="false"
                    android:editable="false"
                    android:id="@+id/fromdate"
                    android:paddingLeft="10dp"
                    android:hint="From date"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
                <EditText
                    android:focusable="false"
                    android:editable="false"
                    android:id="@+id/toDate"
                    android:paddingLeft="10dp"
                    android:textColor="@color/black"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:hint="To date"
                    android:inputType="textCapCharacters"
                    android:layout_height="40dp"
                    android:background="@drawable/box_background"
                    />
            </LinearLayout>
            </LinearLayout>
            <Button
                android:id="@+id/stmtbutton"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Statement"/>

            <TableLayout
                android:layout_marginTop="20dp"
                android:layout_marginLeft="40dp"
                android:layout_marginRight="40dp"
                android:id="@+id/StatetableLayout"
                android:layout_marginBottom="40dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            </TableLayout>

            <TextView
                android:id="@+id/place"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:text="Place : FRANCISTOWN"
                android:textColor="@color/black" />
            <TextView
                android:id="@+id/datebottom"
                android:layout_marginLeft="30dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:layout_marginBottom="30dp"
                android:text="Date: 04-07-2024"/>

            <TextView
                android:id="@+id/statement"
                android:layout_gravity="right"
                android:layout_marginRight="40dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/darkgrey"
                android:layout_marginBottom="30dp"
                android:text="Statement generated on 04-07-2024"/>

            <Button
                android:visibility="gone"
                android:id="@+id/generateBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generate PDF" />
        </LinearLayout>

    </ScrollView>
</RelativeLayout>