<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/WH2"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".DetailScreen.DeviceDetailsActivity">
    <include layout="@layout/background_image" />
    <ScrollView
       style="@style/WH2">
    <LinearLayout
       style="@style/WH4"
        android:orientation="vertical">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="?attr/colorPrimary"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light">
            <LinearLayout
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/back_img"
                    style="@style/WH1"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/back_btn_ic"
                    android:layout_marginStart="20dp" />
                <TextView
                    android:layout_marginStart="20dp"
                    android:id="@+id/headertext"
                    android:text="Device Details"
                    android:textStyle="bold"
                    style="@style/MAtab"/>
            </LinearLayout>
            <ImageView
                android:visibility="gone"
                android:id="@+id/deledevBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="50dp"
                android:contentDescription="Used to delete the device"
                android:src="@drawable/delete_ic" />
            <ImageView
                android:visibility="gone"
                android:id="@+id/editableBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/edit_ic"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="80dp" />
            <ImageView
                android:id="@+id/dd_help_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="20dp"
                android:src="@drawable/ic_help"/>
        </RelativeLayout>
        <LinearLayout
            android:layout_marginTop="50dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_marginStart="10dp"
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:text="Device Id"
                        style="@style/UDtext"/>
                    <TextView
                        android:id="@+id/textdevicename"
                        android:layout_marginTop="25dp"
                        android:text="Device Name"
                        style="@style/UDtext"/>
                    <TextView
                        android:id="@+id/textidentification"
                        android:layout_marginTop="25dp"
                        android:text="Device Identification Number"
                        style="@style/UDtext"/>
                    <TextView
                        android:id="@+id/textmodel"
                        android:layout_marginTop="25dp"
                        android:text="Device Model"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="DEVICE MAKE"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="LOCATION"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="STORE ID"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="FINGER PRINT ENABLED"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="FACE RECOGNITION ENABLED"
                        style="@style/UDtext"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_marginStart="40dp"
                    android:layout_marginEnd="10dp"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <EditText
                        android:layout_marginTop="5dp"
                        android:id="@+id/editDeviceId"
                        android:digits="@string/AlphaNumeric"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Enter Device Name"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editDeviceName"
                        android:digits="@string/AlphaNumeric"
                        style="@style/UDedtext"/>
                    <EditText
                        android:digits="@string/alphanumeric"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editDeviceIdNo"
                        android:hint="Enter Device Number"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Enter Device Model"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editDeviceModel"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Enter Device Make"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editDeviceMake"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Enter Location"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editLocation"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Enter Store Id"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editStoreId"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Select"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editFingerPrint"
                        android:focusable="false"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Select"
                        android:layout_marginTop="5dp"
                        android:focusable="false"
                        android:id="@+id/editFaceReg"
                        style="@style/UDedtext"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_marginLeft="10dp"
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:text="Defined User"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="Approved User"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="Alter User 1"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="Alter User 2"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="Device Status"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="Unit Id"
                        android:id="@+id/textunitid"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="Unit Name"
                        style="@style/UDtext"/>
                    <TextView
                        android:layout_marginTop="25dp"
                        android:text="Unit Type"
                        style="@style/UDtext"/>
                    <TextView
                        android:id="@+id/textterminalid"
                        android:layout_marginTop="25dp"
                        android:text="Terminal Id"
                        style="@style/UDtext"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_marginLeft="40dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <EditText
                        android:hint="Select"
                        android:editable="false"
                        android:focusable="false"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:id="@+id/editDefinedUser"
                        android:layout_marginTop="5dp"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Select"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:id="@+id/editApprovedUser"
                        android:layout_marginTop="5dp"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Select"
                        android:inputType="textCapCharacters"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:id="@+id/alterUser1"
                        android:layout_marginTop="5dp"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Select"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:id="@+id/alterUser2"
                        android:layout_marginTop="5dp"
                        style="@style/UDedtext"/>
                    <EditText
                        android:text="ACTIVE"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editDeviceStatus"
                        style="@style/UDedtext"/>
                    <EditText
                        android:hint="Select"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editUnitId"
                        style="@style/UDedtext"/>
                    <EditText
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:layout_marginTop="5dp"
                        android:id="@+id/editUnitName"
                        android:enabled="false"
                        style="@style/UDedtext"/>
                    <EditText
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
                        android:layout_marginTop="5dp"
                        android:enabled="false"
                        android:id="@+id/editUnitType"
                        style="@style/UDedtext"/>
                    <EditText
                        android:id="@+id/editTermId"
                        android:hint="Enter Terminal Id"
                        android:digits="@string/alphanumeric"
                        android:layout_marginTop="5dp"
                        style="@style/UDedtext"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_marginTop="20dp"
            style="@style/WH4"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginBottom="40dp"
            android:orientation="horizontal">
            <Button
                android:id="@+id/submitbtn"
                android:visibility="invisible"
                android:text="Update"
                style="@style/UDbtn"/>
            <Button
                android:visibility="gone"
                android:id="@+id/verifybtn"
                style="@style/UDbtn"
                android:text="Verify"/>
        </LinearLayout>
    </LinearLayout>
    </ScrollView>
</RelativeLayout>